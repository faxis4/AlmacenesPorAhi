<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlmacenesPorAhi.ViewModels"
             x:Class="AlmacenesPorAhi.Views.ClienteDetailPage"
             Title="{Binding Titulo}"
             BackgroundColor="#FAF7F2">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16"
                             MaximumWidthRequest="600" HorizontalOptions="Center">

            <Border Background="#FFFFFF" StrokeThickness="0" Padding="20"
                    StrokeShape="RoundRectangle 16">
                <Border.Shadow>
                    <Shadow Brush="#2D4236" Opacity="0.08" Radius="12" Offset="0,4" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <Border WidthRequest="80" HeightRequest="80"
                            Background="#E8F0E4" StrokeThickness="0"
                            StrokeShape="RoundRectangle 40">
                            <Label Text="{Binding Emoji}" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <Label Text="{Binding NombreCompleto}" FontSize="22"
                           FontAttributes="Bold" TextColor="#1E2522"
                           HorizontalTextAlignment="Center" />

                    <BoxView HeightRequest="1" Color="#EAE3D9" HorizontalOptions="Fill" />

                    <VerticalStackLayout Spacing="16" HorizontalOptions="Fill"
                                         WidthRequest="320">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="RUT" FontSize="12" TextColor="#7A847C" />
                            <Label Text="{Binding Rut}" FontSize="16"
                                   TextColor="#1E2522" />
                            <BoxView HeightRequest="1" Color="#F0ECE4" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Email" FontSize="12" TextColor="#7A847C" />
                            <Label Text="{Binding Email}" FontSize="16"
                                   TextColor="#1E2522" />
                            <BoxView HeightRequest="1" Color="#F0ECE4" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Teléfono" FontSize="12" TextColor="#7A847C" />
                            <Label Text="{Binding Telefono}" FontSize="16"
                                   TextColor="#1E2522" />
                            <BoxView HeightRequest="1" Color="#F0ECE4" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Género" FontSize="12" TextColor="#7A847C" />
                            <Label Text="{Binding Genero}" FontSize="16"
                                   TextColor="#1E2522" />
                            <BoxView HeightRequest="1" Color="#F0ECE4" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Dirección" FontSize="12" TextColor="#7A847C" />
                            <Label Text="{Binding Direccion}" FontSize="16"
                                   TextColor="#1E2522" />
                            <BoxView HeightRequest="1" Color="#F0ECE4" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Preferencias" FontSize="12" TextColor="#7A847C" />
                            <Label Text="{Binding Preferencias}" FontSize="16"
                                   TextColor="#1E2522" />
                            <BoxView HeightRequest="1" Color="#F0ECE4" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Estado" FontSize="12" TextColor="#7A847C" />
                            <Border Background="#E8F0E4" StrokeThickness="0"
                                    Padding="10,4" StrokeShape="RoundRectangle 6"
                                    HorizontalOptions="Start">
                                <Label Text="{Binding Estado}" FontSize="13"
                                       TextColor="#2D4236" />
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Volver" HeightRequest="48"
                    BackgroundColor="Transparent" TextColor="#7A847C"
                    BorderColor="#D8D0C2" BorderWidth="1"
                    Command="{Binding VolverCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
