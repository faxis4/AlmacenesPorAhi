<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlmacenesPorAhi.ViewModels"
             x:Class="AlmacenesPorAhi.Views.ProductoFormPage"
             x:Name="Pagina"
             x:DataType="vm:ProductoFormViewModel"
             Title="{Binding Titulo}"
             BackgroundColor="#FAF7F2">

    <ScrollView>
        <VerticalStackLayout Padding="14" Spacing="14"
                             MaximumWidthRequest="600" HorizontalOptions="Center">

            <Border Background="#FFFFFF" StrokeThickness="0" Padding="14"
                    StrokeShape="RoundRectangle 16">
                <Border.Shadow>
                    <Shadow Brush="#2D4236" Opacity="0.08" Radius="12" Offset="0,4" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="12">

                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Grid WidthRequest="100" HeightRequest="100" HorizontalOptions="Center">
                            <Border Background="#F1EADD" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14">
                                <Label Text="{Binding Emoji}" FontSize="36"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Border IsVisible="{Binding TieneImagen}" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14" IsClippedToBounds="True">
                                <Image Source="{Binding ImagenUrl}" Aspect="AspectFill" />
                            </Border>
                        </Grid>
                        <Button Text="Seleccionar foto" FontSize="16"
                                BackgroundColor="Transparent" TextColor="#2D4236"
                                BorderColor="#2D4236" BorderWidth="1" HeightRequest="32"
                                Padding="10,0"
                                Command="{Binding SeleccionarFotoCommand}" />
                    </VerticalStackLayout>

                    <Label Text="Datos del producto" FontAttributes="Bold"
                           FontSize="16" TextColor="#2D4236" />

                    <VerticalStackLayout Spacing="3">
                        <Label Text="Nombre" FontSize="16" TextColor="#7A847C" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 8" Padding="8,0" HeightRequest="42">
                            <Entry Text="{Binding Nombre}" Placeholder="Ej: Polera basica"
                                   FontSize="16" TextColor="#1E2522" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="3">
                        <Label Text="Descripcion" FontSize="16" TextColor="#7A847C" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 8" Padding="8,4"
                                HeightRequest="60">
                            <Editor Text="{Binding Descripcion}"
                                    Placeholder="Descripcion (opcional)"
                                    FontSize="16" TextColor="#1E2522" AutoSize="TextChanges" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="3">
                        <Label Text="Categoria" FontSize="16" TextColor="#7A847C" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 8" Padding="8,0" HeightRequest="42">
                            <Entry Text="{Binding Categoria}" Placeholder="Ej: Poleras, Pantalones..."
                                   FontSize="16" TextColor="#1E2522" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="3">
                        <Label Text="Talla" FontSize="16" TextColor="#7A847C" />
                        <HorizontalStackLayout Spacing="12"
                                RadioButtonGroup.GroupName="talla"
                                RadioButtonGroup.SelectedValue="{Binding Talla}">
                            <RadioButton Content="XS" Value="XS" FontSize="14" TextColor="#1E2522" />
                            <RadioButton Content="S" Value="S" FontSize="14" TextColor="#1E2522" />
                            <RadioButton Content="M" Value="M" FontSize="14" TextColor="#1E2522" />
                            <RadioButton Content="L" Value="L" FontSize="14" TextColor="#1E2522" />
                            <RadioButton Content="XL" Value="XL" FontSize="14" TextColor="#1E2522" />
                            <RadioButton Content="XXL" Value="XXL" FontSize="14" TextColor="#1E2522" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="3">
                        <Label Text="Color" FontSize="16" TextColor="#7A847C" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 8" Padding="8,0" HeightRequest="42">
                            <Entry Text="{Binding Color}" Placeholder="Ej: Azul"
                                   FontSize="16" TextColor="#1E2522" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="3">
                        <Label Text="Estado" FontSize="16" TextColor="#7A847C" />
                        <VerticalStackLayout Spacing="4"
                                RadioButtonGroup.GroupName="estado"
                                RadioButtonGroup.SelectedValue="{Binding Estado}">
                            <RadioButton Content="Activo" Value="Activo" FontSize="15"
                                         TextColor="#2D4236" />
                            <RadioButton Content="Agotado" Value="Agotado" FontSize="15"
                                         TextColor="#A4453A" />
                            <RadioButton Content="Descontinuado" Value="Descontinuado" FontSize="15"
                                         TextColor="#8A6A3E" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="3">
                            <Label Text="Precio (CLP)" FontSize="16" TextColor="#7A847C" />
                            <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8" Padding="8,0" HeightRequest="42">
                                <Entry Text="{Binding Precio}" Keyboard="Numeric" Placeholder="0"
                                       FontSize="16" TextColor="#1E2522" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                            <Label Text="Stock" FontSize="16" TextColor="#7A847C" />
                            <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8" Padding="8,0" HeightRequest="42">
                                <Entry Text="{Binding Stock}" Keyboard="Numeric" Placeholder="0"
                                       FontSize="16" TextColor="#1E2522" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button Text="Guardar" HeightRequest="44"
                    BackgroundColor="#E76F51" TextColor="#FFFFFF"
                    FontAttributes="Bold" FontSize="15"
                    Command="{Binding GuardarCommand}" />

            <Button Text="Volver" HeightRequest="40"
                    BackgroundColor="Transparent" TextColor="#7A847C"
                    BorderColor="#D8D0C2" BorderWidth="1"
                    Command="{Binding CancelarCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
