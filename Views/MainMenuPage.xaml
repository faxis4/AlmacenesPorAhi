<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlmacenesPorAhi.ViewModels"
             x:Class="AlmacenesPorAhi.Views.MainMenuPage"
             x:DataType="vm:MainMenuViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAF7F2">

    <ScrollView>
        <VerticalStackLayout Spacing="20"
                             Padding="28,60,28,28"
                             MaximumWidthRequest="520"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

            <Label Text="¡Bienvenido!"
                   FontSize="20"
                   TextColor="#7A847C"
                   HorizontalOptions="Center" />

            <Image Source="almacenapp_logo.png"
                   Aspect="AspectFit"
                   HeightRequest="130"
                   HorizontalOptions="Center" />

            <Label HorizontalOptions="Center" HorizontalTextAlignment="Center">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Almacenes " FontSize="30" FontAttributes="Bold" TextColor="#2D4236" />
                        <Span Text="Por Ahí" FontSize="30" FontAttributes="Bold" TextColor="#E76F51" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <BoxView HeightRequest="3" WidthRequest="60" CornerRadius="2"
                     Color="#D4A373" HorizontalOptions="Center" />

            <BoxView HeightRequest="20" Color="Transparent" />

            <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Button Text="Inventario"
                            HeightRequest="44"
                            WidthRequest="130"
                            CornerRadius="22"
                            BackgroundColor="#E76F51"
                            TextColor="#FFFFFF"
                            FontSize="14"
                            FontAttributes="Bold"
                            Padding="0"
                            Command="{Binding IrAInventarioCommand}" />
                    <Label Text="Productos"
                           FontSize="11"
                           TextColor="#7A847C"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Button Text="Clientes"
                            HeightRequest="44"
                            WidthRequest="130"
                            CornerRadius="22"
                            BackgroundColor="#2D4236"
                            TextColor="#FFFFFF"
                            FontSize="14"
                            FontAttributes="Bold"
                            Padding="0"
                            Command="{Binding IrAClientesCommand}" />
                    <Label Text="Clientes"
                           FontSize="11"
                           TextColor="#7A847C"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
