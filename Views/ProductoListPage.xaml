<?xml version="1.0" encoding="utf-8" ?>
<!--
    VISTA: ProductoListPage (listado del modulo de inventario)
    Capa VIEW del patron MVVM. Solo define interfaz; toda accion la resuelve el
    ViewModel mediante bindings.

    Paleta Earthy Premium: fondo lino, tarjetas blancas, primario verde bosque,
    acento terracota SOLO en el boton de accion principal.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlmacenesPorAhi.ViewModels"
             xmlns:models="clr-namespace:AlmacenesPorAhi.Models"
             x:Class="AlmacenesPorAhi.Views.ProductoListPage"
             x:Name="Pagina"
             x:DataType="vm:ProductoListViewModel"
             Title="{Binding Titulo}"
             BackgroundColor="#FAF7F2">

    <Grid RowDefinitions="Auto,*,Auto"
          MaximumWidthRequest="820"
          HorizontalOptions="Center">

        <!-- Banner de error (rojo funcional). Visible solo si HayError. -->
        <Border Grid.Row="0"
                IsVisible="{Binding HayError}"
                Background="#FBEAE5"
                Stroke="#E8C4B8"
                StrokeThickness="1"
                Margin="14,14,14,0"
                Padding="14"
                StrokeShape="RoundRectangle 12">
            <Label Text="{Binding MensajeError}" TextColor="#8A3B28" FontSize="13" />
        </Border>

        <!-- Indicador de carga -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding EstaCargando}"
                           IsVisible="{Binding EstaCargando}"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="#2D4236" />

        <!-- Lista de productos -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Productos}"
                        Margin="14,12,14,4">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="6">
                    <Label Text="Sin productos" FontSize="18" FontAttributes="Bold"
                           TextColor="#2D4236" HorizontalOptions="Center" />
                    <Label Text="Agrega tu primer producto con el boton de abajo."
                           TextColor="#7A847C" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Producto">
                    <!-- Tarjeta blanca con sombra suave -->
                    <Border Background="#FFFFFF" StrokeThickness="0" Margin="0,7"
                            StrokeShape="RoundRectangle 16">
                        <Border.Shadow>
                            <Shadow Brush="#2D4236" Opacity="0.10" Radius="12" Offset="0,4" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="0">

                            <Grid ColumnDefinitions="Auto,*" Padding="14" ColumnSpacing="14">

                                <!-- Foto del producto (o marcador si no hay imagen) -->
                                <Grid Grid.Column="0" WidthRequest="84" HeightRequest="84">
                                    <Border Background="#F1EADD" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12">
                                        <Label Text="Sin foto" FontSize="11" TextColor="#B6A88E"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Border IsVisible="{Binding TieneImagen}" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12" IsClippedToBounds="True">
                                        <Image Source="{Binding ImagenUrl}" Aspect="AspectFill" />
                                    </Border>
                                </Grid>

                                <!-- Datos del producto -->
                                <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                    <Label Text="{Binding Nombre}" FontAttributes="Bold"
                                           FontSize="16" TextColor="#2D4236" />

                                    <HorizontalStackLayout Spacing="8">
                                        <!-- Etiqueta de categoria en oro viejo -->
                                        <Border Background="#F0E6D6" StrokeThickness="0"
                                                Padding="8,3" StrokeShape="RoundRectangle 8">
                                            <Label Text="{Binding Categoria}" FontSize="11"
                                                   TextColor="#8A6A3E" />
                                        </Border>
                                        <Label FontSize="12" TextColor="#7A847C" VerticalOptions="Center">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0} · {1}">
                                                    <Binding Path="Talla" />
                                                    <Binding Path="Color" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </HorizontalStackLayout>

                                    <Label FontSize="12" TextColor="#7A847C">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} · {1} en stock">
                                                <Binding Path="Estado" />
                                                <Binding Path="Stock" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>

                                    <Label Text="{Binding Precio, StringFormat='$ {0:N0}'}"
                                           FontSize="17" FontAttributes="Bold" TextColor="#1E2522" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#EAE3D9" />

                            <!-- Acciones (no usan terracota, reservada al CTA) -->
                            <Grid ColumnDefinitions="*,*" Padding="8" ColumnSpacing="8">
                                <Button Grid.Column="0" Text="Editar" FontSize="13"
                                        BackgroundColor="Transparent" TextColor="#2D4236"
                                        BorderColor="#2D4236" BorderWidth="1"
                                        Command="{Binding Source={x:Reference Pagina}, Path=BindingContext.EditarCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="1" Text="Eliminar" FontSize="13"
                                        BackgroundColor="Transparent" TextColor="#A4453A"
                                        BorderColor="#E1B3A8" BorderWidth="1"
                                        Command="{Binding Source={x:Reference Pagina}, Path=BindingContext.EliminarCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ACCION PRINCIPAL: acento terracota -->
        <Button Grid.Row="2" Text="+   Agregar producto"
                Margin="14,6,14,14" HeightRequest="54"
                BackgroundColor="#E76F51" TextColor="#FFFFFF"
                FontAttributes="Bold" FontSize="16"
                Command="{Binding AgregarCommand}" />
    </Grid>
</ContentPage>
