<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlmacenesPorAhi.ViewModels"
             x:Class="AlmacenesPorAhi.Views.ProductoDetailPage"
             Title="{Binding Titulo}"
             BackgroundColor="#FAF7F2">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16"
                             MaximumWidthRequest="600" HorizontalOptions="Center">

            <Border Background="#FFFFFF" StrokeThickness="0" Padding="20"
                    StrokeShape="RoundRectangle 16">
                <Border.Shadow>
                    <Shadow Brush="#2D4236" Opacity="0.08" Radius="12" Offset="0,4" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="20">

                    <Grid HeightRequest="180" HorizontalOptions="Fill">
                        <Border Background="#F1EADD" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Label Text="{Binding Emoji}" FontSize="48"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Border IsVisible="{Binding TieneImagen}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" IsClippedToBounds="True">
                            <Image Source="{Binding ImagenUrl}" Aspect="AspectFill" />
                        </Border>
                    </Grid>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Nombre}" FontSize="22"
                               FontAttributes="Bold" TextColor="#1E2522" />
                        <Label Text="{Binding Descripcion}" FontSize="14"
                               TextColor="#7A847C" />
                    </VerticalStackLayout>

                    <Label Text="{Binding Precio, StringFormat='$ {0:N0}'}" FontSize="26"
                           FontAttributes="Bold" TextColor="#E76F51" />

                    <BoxView HeightRequest="1" Color="#EAE3D9" />

                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="14" ColumnSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Categoría"
                               FontSize="13" TextColor="#7A847C" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Categoria}"
                               FontSize="15" TextColor="#1E2522" FontAttributes="Bold" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Talla"
                               FontSize="13" TextColor="#7A847C" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Talla}"
                               FontSize="15" TextColor="#1E2522" FontAttributes="Bold" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Color"
                               FontSize="13" TextColor="#7A847C" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Color}"
                               FontSize="15" TextColor="#1E2522" FontAttributes="Bold" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Stock"
                               FontSize="13" TextColor="#7A847C" />
                        <Label Grid.Row="3" Grid.Column="1">
                            <Label.Text>
                                <Binding Path="Stock" StringFormat="{}{0} unidades" />
                            </Label.Text>
                        </Label>
                    </Grid>

                    <HorizontalStackLayout Spacing="8">
                        <Border Background="#F0E6D6" StrokeThickness="0"
                                Padding="12,6" StrokeShape="RoundRectangle 8">
                            <Label Text="{Binding Estado}" FontSize="12" TextColor="#8A6A3E" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Volver" HeightRequest="48"
                    BackgroundColor="Transparent" TextColor="#7A847C"
                    BorderColor="#D8D0C2" BorderWidth="1"
                    Command="{Binding VolverCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
