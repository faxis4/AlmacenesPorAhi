<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlmacenesPorAhi.ViewModels"
             xmlns:models="clr-namespace:AlmacenesPorAhi.Models"
             x:Class="AlmacenesPorAhi.Views.ClienteListPage"
             x:Name="Pagina"
             x:DataType="vm:ClienteListViewModel"
             Title="{Binding Titulo}"
             BackgroundColor="#FAF7F2">

    <Grid RowDefinitions="Auto,*,Auto"
          MaximumWidthRequest="820"
          HorizontalOptions="Center">

        <Border Grid.Row="0"
                IsVisible="{Binding HayError}"
                Background="#FBEAE5"
                Stroke="#E8C4B8"
                StrokeThickness="1"
                Margin="14,14,14,0"
                Padding="14"
                StrokeShape="RoundRectangle 12">
            <Label Text="{Binding MensajeError}" TextColor="#8A3B28" FontSize="13" />
        </Border>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding EstaCargando}"
                           IsVisible="{Binding EstaCargando}"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="#2D4236" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Clientes}"
                        Margin="14,12,14,4">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="6">
                    <Label Text="Sin clientes" FontSize="18" FontAttributes="Bold"
                           TextColor="#2D4236" HorizontalOptions="Center" />
                    <Label Text="Agrega tu primer cliente con el boton de abajo."
                           TextColor="#7A847C" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Cliente">
                    <Border Background="#FFFFFF" StrokeThickness="0" Margin="0,7"
                            StrokeShape="RoundRectangle 16">
                        <Border.Shadow>
                            <Shadow Brush="#2D4236" Opacity="0.10" Radius="12" Offset="0,4" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="0">

                            <Grid ColumnDefinitions="Auto,*" Padding="14" ColumnSpacing="14">

                                <Border Grid.Column="0" WidthRequest="60" HeightRequest="60"
                                        Background="#E8F0E4" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 30">
                                    <Label Text="{Binding Inicial}" FontSize="22"
                                           FontAttributes="Bold" TextColor="#2D4236"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding NombreCompleto}" FontAttributes="Bold"
                                           FontSize="16" TextColor="#2D4236" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Estado}" FontSize="12" TextColor="#7A847C" />
                                        <Label Text="·" FontSize="12" TextColor="#D8D0C2" />
                                        <Label Text="{Binding Telefono}" FontSize="12" TextColor="#7A847C" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Email}" FontSize="12" TextColor="#7A847C" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#EAE3D9" />

                            <Grid ColumnDefinitions="*,*,*" Padding="8" ColumnSpacing="8">
                                <Button Grid.Column="0" Text="Ver" FontSize="13"
                                        BackgroundColor="Transparent" TextColor="#2D4236"
                                        BorderColor="#D4A373" BorderWidth="1"
                                        Command="{Binding Source={x:Reference Pagina}, Path=BindingContext.VerCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="1" Text="Modificar" FontSize="13"
                                        BackgroundColor="Transparent" TextColor="#2D4236"
                                        BorderColor="#2D4236" BorderWidth="1"
                                        Command="{Binding Source={x:Reference Pagina}, Path=BindingContext.ModificarCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="2" Text="Eliminar" FontSize="13"
                                        BackgroundColor="Transparent" TextColor="#A4453A"
                                        BorderColor="#E1B3A8" BorderWidth="1"
                                        Command="{Binding Source={x:Reference Pagina}, Path=BindingContext.EliminarCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="+   Agregar cliente"
                Margin="14,6,14,14" HeightRequest="54"
                BackgroundColor="#E76F51" TextColor="#FFFFFF"
                FontAttributes="Bold" FontSize="16"
                Command="{Binding AgregarCommand}" />
    </Grid>
</ContentPage>
