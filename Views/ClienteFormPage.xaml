<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlmacenesPorAhi.ViewModels"
             x:Class="AlmacenesPorAhi.Views.ClienteFormPage"
             x:DataType="vm:ClienteFormViewModel"
             Title="{Binding Titulo}"
             BackgroundColor="#FAF7F2">

    <ScrollView>
        <Grid>
        <VerticalStackLayout Padding="16" Spacing="16"
                             MaximumWidthRequest="600" HorizontalOptions="Center">

            <Border Background="#FFFFFF" StrokeThickness="0" Padding="18"
                    StrokeShape="RoundRectangle 16">
                <Border.Shadow>
                    <Shadow Brush="#2D4236" Opacity="0.08" Radius="12" Offset="0,4" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="16">

                    <Border Background="#D4A373" StrokeThickness="0" Padding="10,6"
                            StrokeShape="RoundRectangle 10" IsVisible="{Binding ModoLectura}">
                        <Label Text="SOLO LECTURA" FontAttributes="Bold" FontSize="13"
                               TextColor="#FFFFFF" HorizontalOptions="Center" />
                    </Border>

                    <Label Text="Datos del cliente" FontAttributes="Bold"
                           FontSize="18" TextColor="#2D4236" />

                    <!-- RUT -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="RUT" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                        <Label Text="{Binding Rut}" FontSize="15" TextColor="#1E2522"
                               IsVisible="{Binding ModoLectura}" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="10,0"
                                IsVisible="{Binding ModoEdicion}">
                            <Entry Text="{Binding Rut}" Placeholder="Ej: 12.345.678-9" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Nombre + Apellido paterno -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Nombre" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                            <Label Text="{Binding Nombre}" FontSize="15" TextColor="#1E2522"
                                   IsVisible="{Binding ModoLectura}" />
                            <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="10,0"
                                    IsVisible="{Binding ModoEdicion}">
                                <Entry Text="{Binding Nombre}" Placeholder="Ej: Juan" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Apellido paterno" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                            <Label Text="{Binding ApellidoPaterno}" FontSize="15" TextColor="#1E2522"
                                   IsVisible="{Binding ModoLectura}" />
                            <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="10,0"
                                    IsVisible="{Binding ModoEdicion}">
                                <Entry Text="{Binding ApellidoPaterno}" Placeholder="Ej: Perez" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Apellido materno -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Apellido materno" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                        <Label Text="{Binding ApellidoMaterno}" FontSize="15" TextColor="#1E2522"
                               IsVisible="{Binding ModoLectura}" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="10,0"
                                IsVisible="{Binding ModoEdicion}">
                            <Entry Text="{Binding ApellidoMaterno}" Placeholder="Ej: Gonzalez (opcional)" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email + Telefono -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Email" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                            <Label Text="{Binding Email}" FontSize="15" TextColor="#1E2522"
                                   IsVisible="{Binding ModoLectura}" />
                            <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="10,0"
                                    IsVisible="{Binding ModoEdicion}">
                                <Entry Text="{Binding Email}" Placeholder="Ej: juan@correo.cl" Keyboard="Email" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Telefono" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                            <Label Text="{Binding Telefono}" FontSize="15" TextColor="#1E2522"
                                   IsVisible="{Binding ModoLectura}" />
                            <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10" Padding="10,0"
                                    IsVisible="{Binding ModoEdicion}">
                                <Entry Text="{Binding Telefono}" Placeholder="Ej: +56 9 1234 5678" Keyboard="Telephone" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Direccion -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Direccion" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                        <Label Text="{Binding Direccion}" FontSize="15" TextColor="#1E2522"
                               IsVisible="{Binding ModoLectura}" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="10,4"
                                IsVisible="{Binding ModoEdicion}">
                            <Editor Text="{Binding Direccion}" Placeholder="Direccion del cliente (opcional)"
                                    AutoSize="TextChanges" HeightRequest="70" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Preferencias -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Preferencias" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                        <Label Text="{Binding Preferencias}" FontSize="15" TextColor="#1E2522"
                               IsVisible="{Binding ModoLectura}" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="10,4"
                                IsVisible="{Binding ModoEdicion}">
                            <Editor Text="{Binding Preferencias}" Placeholder="Preferencias del cliente (opcional)"
                                    AutoSize="TextChanges" HeightRequest="60" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Estado -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Estado" FontAttributes="Bold" FontSize="13" TextColor="#7A847C" />
                        <Label Text="{Binding Estado}" FontSize="15" TextColor="#1E2522"
                               IsVisible="{Binding ModoLectura}" />
                        <Border Background="#FFFFFF" Stroke="#EAE3D9" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10" Padding="10,0"
                                IsVisible="{Binding ModoEdicion}">
                            <Picker ItemsSource="{Binding Estados}" SelectedItem="{Binding Estado}" Title="Estado" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Guardar" HeightRequest="54"
                    BackgroundColor="#E76F51" TextColor="#FFFFFF"
                    FontAttributes="Bold" FontSize="16"
                    Command="{Binding GuardarCommand}"
                    IsVisible="{Binding ModoEdicion}" />

            <Button Text="Volver" HeightRequest="48"
                    BackgroundColor="Transparent" TextColor="#7A847C"
                    BorderColor="#D8D0C2" BorderWidth="1"
                    Command="{Binding CancelarCommand}" />
        </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
