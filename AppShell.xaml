<?xml version="1.0" encoding="utf-8" ?>
<!-- AppShell: la pantalla de inicio es el menu principal (MainMenuPage).
     Desde alli se navega al modulo de inventario (ProductoListPage). -->
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:AlmacenesPorAhi.Views"
       x:Class="AlmacenesPorAhi.AppShell"
       Title="Almacenes Por Ahi">

    <ShellContent Title="Inicio"
                  ContentTemplate="{DataTemplate views:MainMenuPage}"
                  Route="MainMenuPage" />

</Shell>
